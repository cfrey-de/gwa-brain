{"version": 1, "embedder": "lexical", "facts": [{"text": "The water level drops to 160 cm after 500 hours of operation.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085853+00:00", "id": "27f2cfe7-1e43-59e8-898f-9e5d9170a157", "context": "Data Sheet — Pump Station P-12"}, {"text": "After 100 hours the water level is still 180 cm.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085900+00:00", "id": "e2c847f5-c170-589b-b42e-866c1f11259e", "context": "Data Sheet — Pump Station P-12"}, {"text": "The operating pressure of the pump is 3.7 bar.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 2.0, "uses": 1, "created_ts": "2026-06-30T07:58:49.085918+00:00", "id": "572ff6e5-67b2-548b-8cd3-48d779870992", "context": "Data Sheet — Pump Station P-12"}, {"text": "The maximum flow rate is 12 litres per second.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085930+00:00", "id": "2a2c8372-ca79-5be8-a601-5a8f7186e94e", "context": "Data Sheet — Pump Station P-12"}, {"text": "The inlet is made of galvanised steel pipe.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085943+00:00", "id": "65cd070c-3d2b-5172-94e7-f5ca75195fc2", "context": "Data Sheet — Pump Station P-12"}, {"text": "The maintenance interval is at least 2000 operating hours.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085953+00:00", "id": "639970f8-3088-5561-8037-3c844dfba6a9", "context": "Data Sheet — Pump Station P-12"}, {"text": "The pump is tested at 25 degrees Celsius.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085960+00:00", "id": "dd2571c8-7537-5eba-b60d-37878206941e", "context": "Data Sheet — Pump Station P-12"}, {"text": "The pump weighs 45 kilograms.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 2.0, "uses": 1, "created_ts": "2026-06-30T07:58:49.085968+00:00", "id": "939c381d-ef02-505d-b88a-59e02ed66333", "context": "Data Sheet — Pump Station P-12"}, {"text": "The housing is rated for outdoor installation.", "source_doc": "01_pump-station-p12_datasheet.txt", "chunk_id": "01_pump-station-p12_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:49.085976+00:00", "id": "cc5c50ab-8306-51ee-b23e-bee336450a9a", "context": "Data Sheet — Pump Station P-12"}, {"text": "The water level drops to 210 cm after 500 hours of operation.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614245+00:00", "id": "d7f1fdd1-463a-54ed-98bf-be7ee5798b51", "context": "Data Sheet — Pump Station P-20"}, {"text": "The operating pressure of the pump is 5.2 bar.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614375+00:00", "id": "97771499-32ea-523a-ba5f-2b9c0e5ffe51", "context": "Data Sheet — Pump Station P-20"}, {"text": "The maximum flow rate is 20 litres per second.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614426+00:00", "id": "cdac1f99-8f9f-5d22-8705-59a733f0ccbd", "context": "Data Sheet — Pump Station P-20"}, {"text": "The maintenance interval is at least 3000 operating hours.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614466+00:00", "id": "3e699959-fe7d-5a5f-a37a-8b25f3ba1630", "context": "Data Sheet — Pump Station P-20"}, {"text": "The pump is tested at 25 degrees Celsius.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614500+00:00", "id": "02df2b8a-7046-5d33-beb0-9e60064260ca", "context": "Data Sheet — Pump Station P-20"}, {"text": "The pump weighs 60 kilograms.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614536+00:00", "id": "1ecfc0e6-916b-558e-bef3-4660113074c4", "context": "Data Sheet — Pump Station P-20"}, {"text": "The inlet is made of stainless steel pipe.", "source_doc": "02_pump-station-p20_datasheet.txt", "chunk_id": "02_pump-station-p20_datasheet.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:50.614568+00:00", "id": "2d942486-5214-5402-aede-053321595525", "context": "Data Sheet — Pump Station P-20"}, {"text": "Q3 Revenue is 500,000 euros", "source_doc": "03_quarterly-figures.txt", "chunk_id": "03_quarterly-figures.txt#s0", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:51.047951+00:00", "id": "7fd62ada-ed23-5cc1-a591-4384c75eb364", "context": "Quarterly Figures — Q3"}, {"text": "Cost of goods sold is 300,000 euros", "source_doc": "03_quarterly-figures.txt", "chunk_id": "03_quarterly-figures.txt#s1", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:51.048015+00:00", "id": "10ed0d27-9116-5d8e-a69d-753e38905717", "context": "Quarterly Figures — Q3"}, {"text": "Operating expenses are 120,000 euros", "source_doc": "03_quarterly-figures.txt", "chunk_id": "03_quarterly-figures.txt#s2", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:51.048028+00:00", "id": "46225ef3-f249-5f4f-8634-12cc6727960a", "context": "Quarterly Figures — Q3"}, {"text": "Gross profit equals revenue minus cost of goods sold, and equals 200,000 euros", "source_doc": "03_quarterly-figures.txt", "chunk_id": "03_quarterly-figures.txt#s3", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:51.048038+00:00", "id": "5275983c-01d8-5351-9311-a561887e1fb6", "context": "Quarterly Figures — Q3"}, {"text": "Operating profit equals gross profit minus operating expenses, and equals 80,000 euros", "source_doc": "03_quarterly-figures.txt", "chunk_id": "03_quarterly-figures.txt#s4", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:51.048046+00:00", "id": "00418de0-209f-5f6a-b8a6-7052864986cd", "context": "Quarterly Figures — Q3"}, {"text": "Profit margin equals operating profit divided by revenue, and equals 16 percent", "source_doc": "03_quarterly-figures.txt", "chunk_id": "03_quarterly-figures.txt#s5", "page": null, "paragraph": null, "weight": 2.0, "uses": 1, "created_ts": "2026-06-30T07:58:51.048055+00:00", "id": "78120526-bb1c-518b-9994-60e2ccefe820", "context": "Quarterly Figures — Q3"}, {"text": "Every pump station must be inspected by a certified technician at least once a year.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.242872+00:00", "id": "1c2bd6e7-745c-5724-a694-38aac194ee9c", "context": "Maintenance Policy"}, {"text": "During the inspection the technician records the water level.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243017+00:00", "id": "6ef5ccc2-fbb2-584b-b5f5-b0e84b6ccdeb", "context": "Maintenance Policy"}, {"text": "During the inspection the technician records the operating pressure.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243076+00:00", "id": "802592f3-7372-5829-84ec-8e7828948e07", "context": "Maintenance Policy"}, {"text": "During the inspection the technician records any unusual noise.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243115+00:00", "id": "40d3f71a-68d8-57e7-af10-2d3c4ce59bd9", "context": "Maintenance Policy"}, {"text": "If the operating pressure falls below the rated value, the station is taken out of service.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243150+00:00", "id": "7c3bc206-cc07-57bc-bc95-c48e771df60a", "context": "Maintenance Policy"}, {"text": "The station is taken out of service until it is repaired.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243189+00:00", "id": "47056215-4daa-5a51-8ec4-61b85c848203", "context": "Maintenance Policy"}, {"text": "Spare parts for the most common wear components are kept on site.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243222+00:00", "id": "ca2cfcaf-1fcb-584b-8517-a2817291e7ef", "context": "Maintenance Policy"}, {"text": "The warranty covers manufacturing defects for two years from the date of installation.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243253+00:00", "id": "5a986b96-d707-56ae-b65d-a0d7a8403703", "context": "Maintenance Policy"}, {"text": "Customers are notified at least one week before a scheduled maintenance visit.", "source_doc": "04_maintenance-policy.txt", "chunk_id": "04_maintenance-policy.txt#c0", "page": null, "paragraph": 1, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:52.243283+00:00", "id": "8fef8182-d16d-5131-85ff-e6c847857f52", "context": "Maintenance Policy"}, {"text": "The inflow is 12 litres per second.", "source_doc": "05_commissioning-report.txt", "chunk_id": "05_commissioning-report.txt#s0", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:53.036152+00:00", "id": "acda83cc-3a82-5318-af96-051c3e4bdc21", "context": "Commissioning Report — Tank T-7"}, {"text": "The outflow is 4 litres per second.", "source_doc": "05_commissioning-report.txt", "chunk_id": "05_commissioning-report.txt#s1", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:53.036280+00:00", "id": "8d7383b6-f421-554d-83f4-96cd3b2a0b7b", "context": "Commissioning Report — Tank T-7"}, {"text": "The net inflow is the inflow minus the outflow, and equals 8 litres per second.", "source_doc": "05_commissioning-report.txt", "chunk_id": "05_commissioning-report.txt#s2", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:53.036334+00:00", "id": "920b87ef-7e8f-502e-96ef-e82f43746e41", "context": "Commissioning Report — Tank T-7"}, {"text": "The tank volume is 9 600 litres.", "source_doc": "05_commissioning-report.txt", "chunk_id": "05_commissioning-report.txt#s3", "page": null, "paragraph": null, "weight": 1.0, "uses": 0, "created_ts": "2026-06-30T07:58:53.036376+00:00", "id": "67f09d40-db26-5670-8349-d040287bc58d", "context": "Commissioning Report — Tank T-7"}, {"text": "The fill time is the tank volume divided by the net inflow, and equals 1 200 seconds.", "source_doc": "05_commissioning-report.txt", "chunk_id": "05_commissioning-report.txt#s4", "page": null, "paragraph": null, "weight": 2.0, "uses": 1, "created_ts": "2026-06-30T07:58:53.036411+00:00", "id": "a8bef6d4-979b-5eef-a7c3-6e64357e4eb2", "context": "Commissioning Report — Tank T-7"}, {"text": "The fill time in minutes is the fill time in seconds divided by 60, and equals 20 minutes.", "source_doc": "05_commissioning-report.txt", "chunk_id": "05_commissioning-report.txt#s5", "page": null, "paragraph": null, "weight": 2.0, "uses": 1, "created_ts": "2026-06-30T07:58:53.036445+00:00", "id": "4db29cd3-82b7-5fad-ae04-0abfe1ae02cf", "context": "Commissioning Report — Tank T-7"}], "graph": {"directed": false, "multigraph": false, "graph": {}, "nodes": [{"id": "27f2cfe7-1e43-59e8-898f-9e5d9170a157"}, {"id": "e2c847f5-c170-589b-b42e-866c1f11259e"}, {"id": "572ff6e5-67b2-548b-8cd3-48d779870992"}, {"id": "2a2c8372-ca79-5be8-a601-5a8f7186e94e"}, {"id": "65cd070c-3d2b-5172-94e7-f5ca75195fc2"}, {"id": "639970f8-3088-5561-8037-3c844dfba6a9"}, {"id": "dd2571c8-7537-5eba-b60d-37878206941e"}, {"id": "939c381d-ef02-505d-b88a-59e02ed66333"}, {"id": "cc5c50ab-8306-51ee-b23e-bee336450a9a"}, {"id": "d7f1fdd1-463a-54ed-98bf-be7ee5798b51"}, {"id": "97771499-32ea-523a-ba5f-2b9c0e5ffe51"}, {"id": "cdac1f99-8f9f-5d22-8705-59a733f0ccbd"}, {"id": "3e699959-fe7d-5a5f-a37a-8b25f3ba1630"}, {"id": "02df2b8a-7046-5d33-beb0-9e60064260ca"}, {"id": "1ecfc0e6-916b-558e-bef3-4660113074c4"}, {"id": "2d942486-5214-5402-aede-053321595525"}, {"id": "7fd62ada-ed23-5cc1-a591-4384c75eb364"}, {"id": "10ed0d27-9116-5d8e-a69d-753e38905717"}, {"id": "46225ef3-f249-5f4f-8634-12cc6727960a"}, {"id": "5275983c-01d8-5351-9311-a561887e1fb6"}, {"id": "00418de0-209f-5f6a-b8a6-7052864986cd"}, {"id": "78120526-bb1c-518b-9994-60e2ccefe820"}, {"id": "1c2bd6e7-745c-5724-a694-38aac194ee9c"}, {"id": "6ef5ccc2-fbb2-584b-b5f5-b0e84b6ccdeb"}, {"id": "802592f3-7372-5829-84ec-8e7828948e07"}, {"id": "40d3f71a-68d8-57e7-af10-2d3c4ce59bd9"}, {"id": "7c3bc206-cc07-57bc-bc95-c48e771df60a"}, {"id": "47056215-4daa-5a51-8ec4-61b85c848203"}, {"id": "ca2cfcaf-1fcb-584b-8517-a2817291e7ef"}, {"id": "5a986b96-d707-56ae-b65d-a0d7a8403703"}, {"id": "8fef8182-d16d-5131-85ff-e6c847857f52"}, {"id": "acda83cc-3a82-5318-af96-051c3e4bdc21"}, {"id": "8d7383b6-f421-554d-83f4-96cd3b2a0b7b"}, {"id": "920b87ef-7e8f-502e-96ef-e82f43746e41"}, {"id": "67f09d40-db26-5670-8349-d040287bc58d"}, {"id": "a8bef6d4-979b-5eef-a7c3-6e64357e4eb2"}, {"id": "4db29cd3-82b7-5fad-ae04-0abfe1ae02cf"}], "links": [{"weight": 1.0, "source": "a8bef6d4-979b-5eef-a7c3-6e64357e4eb2", "target": "4db29cd3-82b7-5fad-ae04-0abfe1ae02cf"}]}, "deps": {"5275983c-01d8-5351-9311-a561887e1fb6": ["7fd62ada-ed23-5cc1-a591-4384c75eb364", "10ed0d27-9116-5d8e-a69d-753e38905717"], "00418de0-209f-5f6a-b8a6-7052864986cd": ["5275983c-01d8-5351-9311-a561887e1fb6", "46225ef3-f249-5f4f-8634-12cc6727960a"], "78120526-bb1c-518b-9994-60e2ccefe820": ["00418de0-209f-5f6a-b8a6-7052864986cd", "7fd62ada-ed23-5cc1-a591-4384c75eb364"], "920b87ef-7e8f-502e-96ef-e82f43746e41": ["acda83cc-3a82-5318-af96-051c3e4bdc21", "8d7383b6-f421-554d-83f4-96cd3b2a0b7b"], "a8bef6d4-979b-5eef-a7c3-6e64357e4eb2": ["920b87ef-7e8f-502e-96ef-e82f43746e41", "67f09d40-db26-5670-8349-d040287bc58d"], "4db29cd3-82b7-5fad-ae04-0abfe1ae02cf": ["a8bef6d4-979b-5eef-a7c3-6e64357e4eb2"]}, "docs": [{"name": "01_pump-station-p12_datasheet.txt", "n_facts": 9, "uploaded_ts": "2026-06-30T07:58:49.088668+00:00"}, {"name": "02_pump-station-p20_datasheet.txt", "n_facts": 7, "uploaded_ts": "2026-06-30T07:58:50.621473+00:00"}, {"name": "03_quarterly-figures.txt", "n_facts": 6, "uploaded_ts": "2026-06-30T07:58:51.049682+00:00"}, {"name": "04_maintenance-policy.txt", "n_facts": 9, "uploaded_ts": "2026-06-30T07:58:52.256511+00:00"}, {"name": "05_commissioning-report.txt", "n_facts": 6, "uploaded_ts": "2026-06-30T07:58:53.043381+00:00"}]}