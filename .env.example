# ============ Chat LLM (any OpenAI-compatible /chat/completions endpoint) ============
LLM_BASE_URL=https://api.example.com/v1
GWA_MODEL=your-chat-model
GWA_MAX_TOKENS=2048                 # raise (e.g. 3000) for reasoning models that emit reasoning tokens
# The chat API key is read from the env var NAMED here; set that variable below.
LLM_API_KEY_ENV=LLM_API_KEY
LLM_API_KEY=
# GWA_TEMPERATURE=0.2
# GWA_RPS=1.0                        # client-side requests/sec
# GWA_MAX_RETRIES=5                  # retries on 429/5xx/connection errors

# ============ Embeddings (OpenAI-compatible /embeddings) ============
GWA_EMBED_MODEL=your-embedding-model
# Embeddings default to the chat endpoint + key above; override only if they live elsewhere:
# EMBED_BASE_URL=                    # default: LLM_BASE_URL
# EMBED_API_KEY_ENV=                 # default: LLM_API_KEY_ENV
# GWA_EMBED_BATCH=64                 # texts per /embeddings request

# --- Examples (pick one; delete the rest) -----------------------------------
# Hosted provider serving chat + embeddings:
#   LLM_BASE_URL=https://api.your-provider.com/v1
#   GWA_MODEL=...   GWA_EMBED_MODEL=...
#   LLM_API_KEY_ENV=PROVIDER_API_KEY   PROVIDER_API_KEY=...
# Mistral:
#   LLM_BASE_URL=https://api.mistral.ai/v1  GWA_MODEL=mistral-large-latest  GWA_EMBED_MODEL=mistral-embed
#   LLM_API_KEY_ENV=MISTRAL_API_KEY    MISTRAL_API_KEY=...
# Local server (Ollama / vLLM / TGI):
#   LLM_BASE_URL=http://localhost:11434/v1  GWA_MODEL=llama3.1  GWA_EMBED_MODEL=nomic-embed-text

# ============ Qdrant ============
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# QDRANT_COLLECTION=gwa_facts

# ============ Storage / ingestion ============
BRAIN_DATA_DIR=/app/data
# BRAIN_MAX_UPLOAD_BYTES=26214400    # 25 MiB default
# GWA_EXTRACT_MODE=auto              # factual | prose | auto | derivation (override per upload in the UI)

# ============ Retrieval / accumulation (fixed once) ============
# GWA_TOP_K=20
# GWA_MIN_SIM=0.30
# GWA_ACCUM_WEIGHT=0.15

# ============ Optional cross-model guard (OFF by default) ============
# GUARD_CROSS_ENABLED=false
# GUARD_CROSS_MODEL=
# GUARD_CROSS_BASE_URL=              # default: LLM_BASE_URL
# GUARD_CROSS_API_KEY_ENV=          # default: LLM_API_KEY_ENV

# ============ Docker compose only (read by compose, not the app) ============
# BRAIN_PORT=8000                    # host port to publish
# BRAIN_BIND=127.0.0.1               # 0.0.0.0 to expose on the LAN (no auth!)
# BRAIN_UID=1000                     # host uid/gid so ./data files are yours
# BRAIN_GID=1000

# ============ Offline/mock mode (no key, no network; test suite) ============
# GWA_MOCK=1
# QDRANT_LOCATION=:memory:
